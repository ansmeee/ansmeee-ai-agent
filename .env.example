# LLM Provider
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# MySQL Master (write)
MYSQL_MASTER_HOST=127.0.0.1
MYSQL_MASTER_PORT=3306
MYSQL_MASTER_USER=root
MYSQL_MASTER_PASSWORD=
MYSQL_MASTER_DATABASE=ai_agent

# MySQL Slave (read, defaults to master)
MYSQL_SLAVE_HOST=127.0.0.1
MYSQL_SLAVE_PORT=3306
MYSQL_SLAVE_USER=root
MYSQL_SLAVE_PASSWORD=
MYSQL_SLAVE_DATABASE=ai_agent

# Redis (optional, falls back to in-memory)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Milvus
MILVUS_ADDRESS=127.0.0.1:19530
MILVUS_USERNAME=root
MILVUS_PASSWORD=Milvus
MILVUS_DBNAME=default
MILVUS_COLLECTION=
MILVUS_TEXT_MAX_LENGTH=65535

# Server
SERVER_PORT=8080
SERVER_MODE=debug
